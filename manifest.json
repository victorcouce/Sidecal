{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "__MSG_appName__",
  "version": "0.1.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",

  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "src/shared/utils.js",
        "src/shared/i18n.js",
        "src/shared/storage.js",
        "src/data/channel-discovery.js",
        "src/data/rss-fetcher.js",
        "src/data/video-cache.js",
        "src/prediction/statistics.js",
        "src/prediction/patterns.js",
        "src/prediction/explainer.js",
        "src/prediction/analyzer.js",
        "src/content/sidebar-entry.js",
        "src/calendar/list-view.js",
        "src/calendar/favorites-ui.js",
        "src/calendar/calendar-ui.js",
        "src/content/calendar-panel.js",
        "src/content/content.js"
      ],
      "css": [
        "src/shared/roboto.css",
        "src/calendar/calendar.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/fonts/roboto-latin.woff2",
        "assets/fonts/roboto-latin-ext.woff2"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
